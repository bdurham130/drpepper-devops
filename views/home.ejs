<%- include('partials/header') %>

<div class="text-center py-5">
  <h1 class="display-4 fw-bold">🎮 Emoji Match</h1>
  <p class="lead text-muted mt-3">
    Test your memory by matching emoji pairs. Compete for the fewest moves!
  </p>

  <div class="mt-4">
    <a href="/game" class="btn btn-primary btn-lg me-2">Play Now</a>
    <a href="/leaderboard" class="btn btn-outline-secondary btn-lg">View Leaderboard</a>
  </div>
</div>

<div class="row mt-5 text-center">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm p-4">
      <h3>🧠</h3>
      <h5>Memory Challenge</h5>
      <p class="text-muted">Flip cards and find matching emoji pairs using your memory.</p>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm p-4">
      <h3>🏆</h3>
      <h5>Leaderboard</h5>
      <p class="text-muted">Your scores are saved to MongoDB. Compete for the top spot.</p>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm p-4">
      <h3>🔒</h3>
      <h5>User Accounts</h5>
      <p class="text-muted">Register and log in to track your personal best scores.</p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
